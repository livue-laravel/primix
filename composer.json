{
    "name": "livue/primix",
    "description": "Primix - Admin panel framework for Laravel based on LiVue",
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Giuseppe Castorina"
        },
        {
            "name": "cCast",
            "email": "software@ccast.it"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/support": "^12.0",
        "livue/livue": "^1.5.0"
    },
    "autoload": {
        "psr-4": {
            "Primix\\": "packages/panel/src/",
            "Primix\\Actions\\": "packages/actions/src/",
            "Primix\\Details\\": "packages/details/src/",
            "Primix\\Forms\\": "packages/forms/src/",
            "Primix\\MultiTenant\\": "packages/multi-tenant/src/",
            "Primix\\Notifications\\": "packages/notifications/src/",
            "Primix\\Support\\": "packages/support/src/",
            "Primix\\Tables\\": "packages/tables/src/",
            "Primix\\Widgets\\": "packages/widgets/src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Actions\\PrimixActionsServiceProvider",
                "Primix\\Details\\PrimixDetailsServiceProvider",
                "Primix\\Forms\\PrimixFormsServiceProvider",
                "Primix\\MultiTenant\\MultiTenantServiceProvider",
                "Primix\\Notifications\\PrimixNotificationsServiceProvider",
                "Primix\\PrimixServiceProvider",
                "Primix\\Support\\PrimixSupportServiceProvider",
                "Primix\\Tables\\PrimixTablesServiceProvider",
                "Primix\\Widgets\\PrimixWidgetsServiceProvider"
            ]
        }
    },
    "scripts": {
        "monorepo:merge": "vendor/bin/monorepo-builder merge",
        "monorepo:propagate": "vendor/bin/monorepo-builder propagate",
        "monorepo:validate": "vendor/bin/monorepo-builder validate",
        "monorepo:release": "vendor/bin/monorepo-builder release",
        "monorepo:release-major": "vendor/bin/monorepo-builder release major",
        "monorepo:release-minor": "vendor/bin/monorepo-builder release minor",
        "monorepo:release-patch": "vendor/bin/monorepo-builder release patch"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symplify/monorepo-builder": true
        }
    },
    "replace": {
        "primix/actions": "0.1.3",
        "primix/details": "0.1.3",
        "primix/forms": "0.1.3",
        "primix/multi-tenant": "0.1.3",
        "primix/notifications": "0.1.3",
        "primix/panel": "0.1.3",
        "primix/support": "0.1.3",
        "primix/tables": "0.1.3",
        "primix/widgets": "0.1.3"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
