{
    "name": "primix/forms",
    "description": "Form builder for Primix admin panel framework",
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Giuseppe Castorina"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "primix/support": "^0.1 || dev-main",
        "primix/actions": "^0.1 || dev-main",
        "livue/livue": "*"
    },
    "autoload": {
        "psr-4": {
            "Primix\\Forms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Forms\\PrimixFormsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
