{
    "name": "primix/forms",
    "description": "Form builder for Primix admin panel framework",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "primix/support": "^0.1.3",
        "primix/actions": "^0.1.3"
    },
    "autoload": {
        "psr-4": {
            "Primix\\Forms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Forms\\PrimixFormsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
