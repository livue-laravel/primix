{
    "name": "primix/multi-tenant",
    "description": "Multi-tenancy support for Primix admin panel framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/events": "^12.0|^13.0",
        "illuminate/queue": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "suggest": {
        "primix/primix": "Required for Panel integration with multi-tenancy"
    },
    "autoload": {
        "psr-4": {
            "Primix\\MultiTenant\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\MultiTenant\\MultiTenantServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
