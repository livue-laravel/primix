{
    "name": "primix/notifications",
    "description": "Notification system for Primix admin panel framework",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Giuseppe Castorina"
        }
    ],
    "require": {
        "php": "^8.2",
        "primix/support": "^0.1.0"
    },
    "autoload": {
        "psr-4": {
            "Primix\\Notifications\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Notifications\\PrimixNotificationsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
