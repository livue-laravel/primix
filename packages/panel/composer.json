{
    "name": "primix/panel",
    "description": "Primix - Admin panel framework for Laravel based on LiVue",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "primix/support": "^0.1.3",
        "primix/forms": "^0.1.3",
        "primix/details": "^0.1.3",
        "primix/tables": "^0.1.3",
        "primix/actions": "^0.1.3",
        "primix/notifications": "^0.1.3",
        "primix/widgets": "^0.1.3"
    },
    "autoload": {
        "psr-4": {
            "Primix\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\PrimixServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
