{
    "name": "primix/primix",
    "description": "Primix - Admin panel framework for Laravel based on LiVue",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "livue/livue": "^1.5.0",
        "primix/support": "^0.3.12",
        "primix/forms": "^0.3.12",
        "primix/details": "^0.3.12",
        "primix/tables": "^0.3.12",
        "primix/actions": "^0.3.12",
        "primix/notifications": "^0.3.12",
        "primix/widgets": "^0.3.12"
    },
    "autoload": {
        "psr-4": {
            "Primix\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\PrimixServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
