{
    "name": "primix/tables",
    "description": "Table builder for Primix admin panel framework",
    "license": "MIT",
    "authors": [
        {
            "name": "Claudio Giuseppe Castorina"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "primix/support": "^0.1.0",
        "primix/actions": "^0.1.0",
        "livue/livue": "*"
    },
    "suggest": {
        "primix/forms": "Required for ExportAction and ImportAction form schemas"
    },
    "autoload": {
        "psr-4": {
            "Primix\\Tables\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Tables\\PrimixTablesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
