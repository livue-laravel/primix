{
    "name": "primix/tables",
    "description": "Table builder for Primix admin panel framework",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "livue/livue": "^1.5.0",
        "primix/support": "^0.3.13",
        "primix/actions": "^0.3.13"
    },
    "suggest": {
        "primix/forms": "Required for ExportAction and ImportAction form schemas"
    },
    "autoload": {
        "psr-4": {
            "Primix\\Tables\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Primix\\Tables\\PrimixTablesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
